# Rust build output.
/target/
*.profraw

# Disc-extracted Sony bytes. NEVER commit (see CLAUDE.md, NOTICE).
/extracted/

# PCSX-Redux probe captures - full RAM dumps, register CSVs, run logs.
# Sony-derived runtime state; regenerable from the probe + a local save.
/captures/

# Local-only archive for retired automation. Resolved investigations live
# here so the on-disk record survives without cluttering the active
# tooling tree. The committed catalogue in
# docs/tooling/pcsx-redux-automation.md is the source of truth for what
# was learned.
/archive/

# Ghidra project DB (per-user, contains analysed Sony executable).
/ghidra/projects/

# Ghidra analysis outputs - regenerable from the project DB and contain
# Sony-derived code/strings (decompiled C, disassembly, extracted path
# strings, function inventories). CLAUDE.md: "no decompressed Sony bytes
# (text strings, sample data, decompiled-C dumps with literal data) get
# checked in". The .py / .lua / .sh tooling under ghidra/scripts/ IS
# committed - it's the original analysis tooling, not Sony output.
/ghidra/scripts/funcs/
/ghidra/scripts/*.csv
/ghidra/scripts/*.json
/ghidra/scripts/*.txt
/ghidra/scripts/*.log
# symbols.json / symbols.lua are name -> address maps generated from the
# funcs/*.txt headers (Ghidra default labels + addresses, no Sony bytes).
# Committed so PCSX-Redux Lua probes can resolve names without bundling
# the funcs/ tree. Regenerate via scripts/pcsx-redux/build-symbols.py.
!/ghidra/scripts/symbols.json
!/ghidra/scripts/symbols.lua
/ghidra/import.log

# Disc images, dumps, and PSX executables - defensive: extracted/ already
# covers the canonical paths, but stop a stray drop into the repo root.
*.bin
*.iso
*.img
*.cue
*.toc
*.mds
*.mdf
/SCUS_*

# Mednafen save states (referenced by scripts/analyze-overlay.sh; the
# canonical location is ~/.mednafen/mcs/, but ignore stray copies here).
*.mc[0-9]
*.mca

# PCSX-Redux closed-loop probe outputs land under captures/<probe>/<run-ts>/
# (the run_probe.sh wrapper defaults LEGAIA_OUT_DIR there). /captures/ above
# already covers them. /logs/ is the legacy default for run-time logs when
# the wrapper falls back outside captures/.
/logs/

# User-local overlay sweep spec (path/label pairs; example committed as .example).
scripts/overlays.spec

# WASM build output - tracked in the repo so the site works without a local rebuild.
# Regenerate via scripts/build-wasm.sh when crates/web-viewer or its deps change.
# site/wasm/.gitignore allows only the specific artifacts needed by viewer.html.

# Local docker compose env (UID/GID overrides). The committed
# `.env.example` documents the available variables; users copy it to
# `.env` and customise.
.env

# Python tooling cache (scripts/*.py).
__pycache__/
*.pyc
*.pyo

# Editors / IDEs.
.idea/
.vscode/
*.swp
*~
*.bak
*.orig

# OS junk.
.DS_Store
Thumbs.db
