#!/usr/bin/env bash
#
# Pre-commit hook: runs the same gates CI runs.
#
# Install (once per clone):
#     scripts/ci/install-hooks.sh
#
# Then every `git commit` runs the same `cargo fmt --check` and
# `cargo clippy -D warnings` that .github/workflows/main-ci.yml runs, so a
# CI break should never reach `main` unless someone explicitly bypasses with
# `--no-verify`.
#
# Format drift is auto-fixed: if `cargo fmt --check` fails, the hook runs
# `cargo fmt --all` and re-stages any previously-staged .rs files that were
# reformatted. Files with both staged AND unstaged changes are NOT auto-fixed
# (re-staging would silently fold the unstaged diff into the commit) -- the
# hook aborts and asks you to resolve the working-tree state first.
#
# Skip (in emergencies only) by exporting `LEGAIA_SKIP_PRECOMMIT=1` for one
# command, e.g. `LEGAIA_SKIP_PRECOMMIT=1 git commit -m "..."`.
#
# Tests are intentionally NOT in the hook -- they take long enough that the
# usual workflow is to run `cargo test --workspace` manually before pushing.

set -euo pipefail

if [[ "${LEGAIA_SKIP_PRECOMMIT:-0}" == "1" ]]; then
    printf '[pre-commit] LEGAIA_SKIP_PRECOMMIT=1 -- skipping checks\n' >&2
    exit 0
fi

# Resolve the repo root so the hook works from worktrees and submodules.
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Doc legibility-density gate. Fails the commit on over-800-char lines or
# over-150-word markdown table cells in staged docs / crate READMEs, so density
# creep can't land. Runs before the Rust-only early-exit so docs-only commits
# are covered too. Bypass with LEGAIA_SKIP_PRECOMMIT=1 (handled above); run
# scripts/ci/check-doc-density.py for a full-corpus audit.
if command -v python3 >/dev/null 2>&1 && [[ -f "scripts/ci/check-doc-density.py" ]]; then
    printf '[pre-commit] doc legibility-density check\n'
    if ! python3 scripts/ci/check-doc-density.py --staged --quiet; then
        printf '[pre-commit] doc density violations above -- reflow long lines or move over-budget table cells into sections (or LEGAIA_SKIP_PRECOMMIT=1 to bypass)\n' >&2
        exit 1
    fi
fi

# VRChat-diorama register-protocol codegen drift gate. When staged changes touch
# scripts/vrc-diorama/, the generated Lua/C# register files must match the schema
# (PRD: hand-editing the generated side is a build error). Bypass via the global
# LEGAIA_SKIP_PRECOMMIT=1 handled above.
VRC_TOUCHED=0
while IFS= read -r path; do
    case "$path" in
        scripts/vrc-diorama/*) VRC_TOUCHED=1; break ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)
if [[ "$VRC_TOUCHED" == "1" ]] && command -v python3 >/dev/null 2>&1 \
    && [[ -f "scripts/vrc-diorama/codegen.py" ]]; then
    printf '[pre-commit] vrc-diorama register codegen drift check\n'
    if ! python3 scripts/vrc-diorama/codegen.py --check; then
        printf '[pre-commit] generated register files are stale -- run scripts/vrc-diorama/codegen.py and stage the result (or LEGAIA_SKIP_PRECOMMIT=1 to bypass)\n' >&2
        exit 1
    fi
fi

# Site internal-link gate. When staged changes touch site/, regenerate-free
# check of the existing generated pages' relative hrefs + anchors. (The full
# regenerate-then-check runs inside site/_gen.py; this catches fragment edits
# whose generated mirror is stale or missing.)
SITE_TOUCHED=0
while IFS= read -r path; do
    case "$path" in
        site/*)
            SITE_TOUCHED=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)
if [[ "$SITE_TOUCHED" == "1" ]] && command -v python3 >/dev/null 2>&1 \
    && [[ -f "scripts/ci/check-site-links.py" ]]; then
    printf '[pre-commit] site internal-link check\n'
    if ! python3 scripts/ci/check-site-links.py --quiet; then
        printf '[pre-commit] broken site links above -- run python3 site/_gen.py and fix the _content hrefs (or LEGAIA_SKIP_PRECOMMIT=1 to bypass)\n' >&2
        exit 1
    fi
fi

# If the commit only touches files outside the Rust workspace (e.g. docs,
# site/, ghidra/scripts/), skip the cargo gates -- they're slow and would
# add nothing.
RUST_TOUCHED=0
while IFS= read -r path; do
    case "$path" in
        Cargo.toml|Cargo.lock|crates/*|rust-toolchain*|.cargo/*)
            RUST_TOUCHED=1
            break
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ "$RUST_TOUCHED" -eq 0 ]]; then
    printf '[pre-commit] no Rust files staged; skipping cargo gates\n'
    exit 0
fi

printf '[pre-commit] cargo fmt --all -- --check\n'
if ! cargo fmt --all -- --check; then
    printf '[pre-commit] format drift detected -- attempting auto-fix\n'

    # Collect staged .rs files (added/copied/modified/renamed).
    staged_rs=()
    while IFS= read -r path; do
        [[ -n "$path" ]] || continue
        staged_rs+=("$path")
    done < <(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')

    # Refuse to auto-fix files that also have unstaged changes -- re-staging
    # them would silently include the unstaged diff in the commit.
    dirty=()
    for f in "${staged_rs[@]:-}"; do
        if ! git diff --quiet -- "$f"; then
            dirty+=("$f")
        fi
    done
    if (( ${#dirty[@]} > 0 )); then
        printf '[pre-commit] cannot auto-fix; these staged files have unstaged changes:\n' >&2
        printf '             %s\n' "${dirty[@]}" >&2
        printf '[pre-commit] run `cargo fmt --all`, review the diff, and re-stage\n' >&2
        exit 1
    fi

    cargo fmt --all

    # Re-stage the originally-staged .rs files that fmt may have rewritten.
    # `git add` is a no-op for files fmt didn't touch, so this is safe to
    # apply to the full set.
    if (( ${#staged_rs[@]} > 0 )); then
        git add -- "${staged_rs[@]}"
    fi

    # Confirm fmt is clean now. If not, something is wrong (e.g. fmt
    # disagrees with itself, or non-staged files block the check).
    if ! cargo fmt --all -- --check; then
        printf '[pre-commit] cargo fmt still reports drift after auto-fix\n' >&2
        exit 1
    fi
    printf '[pre-commit] auto-formatted and re-staged: %d file(s)\n' "${#staged_rs[@]}"
fi

printf '[pre-commit] cargo clippy --all-targets --workspace -- -D warnings\n'
cargo clippy --all-targets --workspace -- -D warnings

# Port-tag drift check (warn-only). Surfaces newly-added `FUN_<addr>` citations
# in engine-crate Rust files that lack a matching `// PORT:` or `// REF:` tag.
# Non-fatal by design - the catalog stays in sync incrementally rather than
# blocking unrelated PRs. Run scripts/ci/check-port-tags.py --strict in CI when
# you want to enforce.
if command -v python3 >/dev/null 2>&1 && [[ -f "scripts/ci/check-port-tags.py" ]]; then
    printf '[pre-commit] port-tag drift check (warn-only)\n'
    python3 scripts/ci/check-port-tags.py --staged --quiet || true
fi

printf '[pre-commit] OK\n'
